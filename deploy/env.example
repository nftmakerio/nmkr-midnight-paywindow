# Place per-environment secrets in /etc/nmkr-paywindow/<network>.env
# and reference them from the systemd unit via EnvironmentFile=.
#
# Copy this file to /etc/nmkr-paywindow/preprod.env (resp. mainnet.env),
# fill in the bearer token, then:
#   sudo chown root:nmkr /etc/nmkr-paywindow/*.env
#   sudo chmod 640 /etc/nmkr-paywindow/*.env

NMKR_STUDIO_API_KEY=replace-with-the-real-bearer-token
