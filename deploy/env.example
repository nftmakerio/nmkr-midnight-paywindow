# Place per-environment secrets in /etc/nmkr-paywindow/<network>.env
# and reference them from the systemd unit via EnvironmentFile=.
#
# Copy this file to /etc/nmkr-paywindow/preprod.env (resp. mainnet.env),
# fill in the secret, then:
#   sudo chown root:nmkr /etc/nmkr-paywindow/*.env
#   sudo chmod 640 /etc/nmkr-paywindow/*.env

# Preferred: TOTP secret ("API token password") issued by NMKR Studio.
# The bridge generates a 6-digit TOTP from this secret, calls
# /GetAccessToken to get a short-lived bearer, caches it and refreshes
# automatically. Each Studio environment has its own secret — never
# reuse the preprod secret on mainnet.
NMKR_STUDIO_TOTP_SECRET=replace-with-the-API-token-password-from-Studio

# Legacy fallback (optional): if a static bearer is set here, it takes
# precedence over the TOTP flow. Mostly useful for short manual tests.
# NMKR_STUDIO_API_KEY=
